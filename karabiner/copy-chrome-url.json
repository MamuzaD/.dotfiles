{
  "description": "Copy Chrome URL with Cmd+Shift+C",
  "manipulators": [
    {
      "conditions": [
        {
          "bundle_identifiers": ["^com\\.google\\.Chrome$"],
          "type": "frontmost_application_if"
        }
      ],
      "from": {
        "key_code": "c",
        "modifiers": { "mandatory": ["left_command", "left_shift"] }
      },
      "to": [
        {
          "key_code": "l",
          "modifiers": ["left_command"]
        },
        {
          "key_code": "c",
          "modifiers": ["left_command"]
        },
        { "key_code": "escape" },
        { "key_code": "escape" }
      ],
      "type": "basic"
    }
  ]
}
